{
  "name": "@inflacion/ui",
  "version": "0.1.0",
  "description": "Design system components extracted from inflacion-personal-ar",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npx @tailwindcss/cli -i src/styles.css -o dist/styles.css --minify",
    "build:js": "tsup",
    "build:css": "npx @tailwindcss/cli -i src/styles.css -o dist/styles.css --minify",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
